<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1220">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 🔥 TOURNAMENT INFO -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#111827">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tournament Name"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvGame"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Game Name"
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/tvPrize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prize ₹10000"
                    android:textColor="#22C55E"
                    android:textStyle="bold"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 🔥 FORM -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#111827">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- TITLE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create Team"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <!-- TEAM NAME -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundMode="outline">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTeamName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Team Name"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- PLAYER NAME -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:boxBackgroundMode="outline">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etleaderid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Leader Name"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 🔥 TEAM TYPE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Team Type"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp"/>

                <RadioGroup
                    android:id="@+id/rgTeamType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <RadioButton
                        android:id="@+id/rbSolo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Solo"
                        android:textColor="#FFFFFF"/>

                    <RadioButton
                        android:id="@+id/rbDuo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Duo"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="12dp"/>

                    <RadioButton
                        android:id="@+id/rbSquad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Squad"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="12dp"/>
                </RadioGroup>

                <!-- 🔥 DYNAMIC PLAYER CONTAINER -->
                <LinearLayout
                    android:id="@+id/playerContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp">

                    <!-- Player 1 -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPlayer1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundMode="outline">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPlayer1"
                            android:hint="Player 1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Player 2 -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPlayer2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:boxBackgroundMode="outline">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPlayer2"
                            android:hint="Player 2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Player 3 -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPlayer3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:boxBackgroundMode="outline">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPlayer3"
                            android:hint="Player 3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Player 4 -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPlayer4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:boxBackgroundMode="outline">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPlayer4"
                            android:hint="Player 4"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <!-- REGISTER BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCreateTeam"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Register Team"
                    android:layout_marginTop="16dp"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="14dp"
                    android:backgroundTint="#2563EB"/>

                <!-- HISTORY BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHistory"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:text="View History"
                    android:layout_marginTop="10dp"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="14dp"
                    android:backgroundTint="#1F2937"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>